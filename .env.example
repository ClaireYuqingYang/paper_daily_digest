# 复制此文件为 .env 并填入真实值（.env 不要提交到 GitHub！）

# Anthropic API Key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server酱 SendKey — https://sct.ftqq.com
# ⚠️ 这个 Key 等同于你的推送密码，不要公开
SERVERCHAN_KEY=SCT...

# Telegraph access token（首次运行后自动生成，从 data/.telegraph_token 复制）
TELEGRAPH_ACCESS_TOKEN=
